# ─── Deepgram (STT) ───────────────────────────────────────────
# Get your key at https://console.deepgram.com
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# ─── ElevenLabs (TTS) ─────────────────────────────────────────
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
# Default: Aria (9BWtsMINqrJLrRacOk9x) — warm, expressive VTuber voice
# Swap for a cloned voice ID here — zero code changes required
ELEVENLABS_VOICE_ID=9BWtsMINqrJLrRacOk9x
# eleven_flash_v2_5 = ~200ms first chunk (recommended); eleven_multilingual_v2 for quality
ELEVENLABS_TTS_MODEL=eleven_flash_v2_5

# ─── Anthropic / Claude ───────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# claude-sonnet-4-6 = best quality/latency; claude-haiku-4-5-20251001 = cheaper/faster
CLAUDE_MODEL=claude-sonnet-4-6

# ─── Server ───────────────────────────────────────────────────
PORT=3001
# Comma-separated list of allowed frontend origins
CORS_ORIGIN=http://localhost:5500,http://127.0.0.1:5500,https://your-project.vercel.app

# ─── Safety ───────────────────────────────────────────────────
# Set to "strict" (blocks more), "moderate" (default), or "permissive"
SAFETY_LEVEL=moderate

# ─── Memory ───────────────────────────────────────────────────
# Max conversation turns to keep in active session memory
MEMORY_MAX_TURNS=20
# Max characters retrieved from long-term lore per query
RAG_MAX_CHARS=800
